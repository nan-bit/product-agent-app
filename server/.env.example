# --- Anthropic (server-side only, never expose to the browser) ---
ANTHROPIC_API_KEY=sk-ant-your-key
# Sonnet 5 gives rich artifacts. Use claude-haiku-4-5 for cheapest/fastest,
# or claude-opus-4-8 for the highest quality.
ANTHROPIC_MODEL=claude-sonnet-5

# --- Model output ---
MAX_OUTPUT_TOKENS=16000

# --- Server ---
PORT=8080

# --- Interview ---
MAX_TURNS=4

# --- Abuse / cost controls ---
# One full interview per IP per window, then "take it and build it yourself".
IP_TURN_BUDGET=4
IP_WINDOW_MS=86400000
REQUESTS_PER_MINUTE=30
MAX_ANSWER_CHARS=4000

# --- CORS ---
# Comma-separated origins allowed to call this API. Lock this to your portfolio.
# Leave empty to allow all (dev only).
ALLOWED_ORIGINS=https://ernan.dev
